# Admin Panel Authentication
ADMIN_PASSWORD=your-secure-password-here

# Required in production: Secret key for signing session cookies (use a random 64+ char string)
# In development, falls back to a random per-process value if not set.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# Google Gemini API (free tier — get key at https://aistudio.google.com/apikey)
# Enables AI-powered spec extraction from scraped product pages
GEMINI_API_KEY=

# Supabase (get these from your Supabase project: Settings → API)
# REQUIRED on Vercel: all file-based stores are replaced with Supabase automatically.
# Without these, writes (verification data, newsletter subscribers, rate limits) will
# fail on Vercel's read-only filesystem.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel Cron Secret (auto-set by Vercel when crons are configured in vercel.json)
# Vercel passes this as "Authorization: Bearer <secret>" to cron endpoints.
# Leave blank in local dev — the cron endpoint skips auth when this is unset.
CRON_SECRET=

# Sentry error monitoring (optional — leave blank to disable)
# Get your DSN at https://sentry.io — create a SvelteKit project
VITE_SENTRY_DSN=
SENTRY_DSN=

# Required for Sentry source map uploads in CI/CD (set in Vercel env, not committed)
# Get at: https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=

# Logging (optional — defaults to 'info'; use 'debug' for verbose output, 'warn' for quiet)
LOG_LEVEL=
