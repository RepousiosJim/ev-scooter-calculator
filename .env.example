# Admin Panel Authentication
ADMIN_PASSWORD=your-secure-password-here

# Required in production: Secret key for signing session cookies (use a random 64+ char string)
# In development, falls back to ADMIN_PASSWORD if not set.
SESSION_SECRET=

# Google Gemini API (free tier — get key at https://aistudio.google.com/apikey)
# Enables AI-powered spec extraction from scraped product pages
GEMINI_API_KEY=

# Supabase (get these from your Supabase project: Settings → API)
# When set, all file-based stores are replaced with Supabase tables automatically.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel KV (production only - auto-populated when linking Vercel KV store)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Sentry error monitoring (optional — leave blank to disable)
# Get your DSN at https://sentry.io — create a SvelteKit project
VITE_SENTRY_DSN=
SENTRY_DSN=

# Logging (optional — defaults to 'info'; use 'debug' for verbose output, 'warn' for quiet)
LOG_LEVEL=
