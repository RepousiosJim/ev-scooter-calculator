{
	"framework": "sveltekit",
	"buildCommand": "npm run build",
	"installCommand": "npm install",
	"devCommand": "npm run dev",

	"functions": {
		"src/routes/api/admin/batch-verify/+server.ts": {
			"maxDuration": 300
		},
		"src/routes/api/admin/discover/+server.ts": {
			"maxDuration": 300
		},
		"src/routes/api/admin/scrape/+server.ts": {
			"maxDuration": 60
		},
		"src/routes/api/admin/auto-verify/+server.ts": {
			"maxDuration": 60
		},
		"src/routes/api/og/+server.ts": {
			"maxDuration": 15
		}
	},

	"crons": [
		{
			"path": "/api/cron/cleanup",
			"schedule": "0 * * * *"
		}
	],

	"headers": [
		{
			"source": "/api/v1/(.*)",
			"headers": [
				{ "key": "Access-Control-Allow-Origin", "value": "*" },
				{ "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
				{ "key": "Access-Control-Allow-Headers", "value": "Content-Type, Accept" }
			]
		},
		{
			"source": "/_app/immutable/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/fonts/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/(favicon\\.svg|pwa-192x192\\.png|pwa-512x512\\.png|robots\\.txt)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=86400, s-maxage=604800"
				}
			]
		},
		{
			"source": "/(.*)",
			"headers": [
				{ "key": "X-Content-Type-Options", "value": "nosniff" },
				{ "key": "X-Frame-Options", "value": "SAMEORIGIN" },
				{ "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
				{ "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
			]
		}
	],

	"redirects": [
		{
			"source": "/api/v1",
			"destination": "/api/v1/",
			"permanent": false
		}
	]
}
